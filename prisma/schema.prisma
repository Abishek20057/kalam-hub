// KalamHub — Prisma Schema
// Module 1 scope: schema file exists and is wired up, but no migrations
// are run yet (Phase 5 is when the database goes live per the Master
// Prompt phase sequence). Models below mirror the TypeScript interfaces
// in src/lib/types/ exactly, so Phase 5 is a direct lift — no redesign.
//
// DO NOT run `prisma migrate dev` until Phase 5 is approved.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DifficultyLevel {
  Beginner
  Intermediate
  Advanced
}

enum ProjectAccessType {
  Free
  Premium
}

enum ActivityCategory {
  Internships
  Workshops
  IndustrialVisits
  Hackathons
  ProjectExpo
  Events
  TeamActivities
  Certifications
}

model Project {
  id            String            @id @default(cuid())
  title         String
  slug          String            @unique
  description   String
  thumbnailUrl  String
  thumbnailAlt  String
  category      String
  categorySlug  String
  tags          Json              // ProjectTag[]
  difficulty    DifficultyLevel
  accessType    ProjectAccessType
  featured      Boolean           @default(false)
  publishedAt   DateTime          @default(now())
  viewCount     Int               @default(0)

  @@index([featured])
  @@index([categorySlug])
}

model Activity {
  id           String            @id @default(cuid())
  title        String
  slug         String            @unique
  category     ActivityCategory
  description  String
  thumbnailUrl String
  thumbnailAlt String
  date         DateTime
  homeFeatured Boolean           @default(false)
  publishedAt  DateTime          @default(now())

  @@index([homeFeatured])
}

model TeamMember {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  role         String
  bio          String?
  photoUrl     String?
  photoAlt     String?
  socialLinks  Json     // SocialLink[]
  homeVisible  Boolean  @default(true)
  displayOrder Int      @default(0)
}

model Technology {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  icon         String
  projectCount Int      @default(0)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
}

model Statistic {
  id           String  @id @default(cuid())
  value        Int
  label        String
  icon         String?
  prefix       String?
  suffix       String?
  displayOrder Int     @default(0)
}

// Generic key-value content store backing Hero, About, Why Choose,
// Innovation Journey, Final CTA — see Architecture Doc Section 10.
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "hero", "about", "benefits", "final_cta"
  data      Json
  updatedAt DateTime @updatedAt
}

model Announcement {
  id            String    @id @default(cuid())
  message       String
  linkText      String?
  linkHref      String?
  isActive      Boolean   @default(false)
  isDismissable Boolean   @default(true)
  startDate     DateTime?
  endDate       DateTime?
}
