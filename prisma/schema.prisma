// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
 
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DifficultyLevel {
  Beginner
  Intermediate
  Advanced
}

// Core Models

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String?   @unique
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  projects Project[]
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  projects Project[] @relation("ProjectTags")
}

model Technology {
  id           String    @id @default(cuid())
  name         String    @unique
  slug         String    @unique
  icon         String?
  projectCount Int       @default(0)
  isActive     Boolean   @default(true)
  displayOrder Int       @default(0)
  projects     Project[] @relation("ProjectTechnologies")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  filename  String
  size      Int // in bytes
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation fields for one-to-one/many thumbnails
  projectThumbnail Project? @relation("ThumbnailImage")

  // Relation fields for one-to-many galleries
  projectGallery   Project? @relation(fields: [projectGalleryId], references: [id])
  projectGalleryId String?
}

model Project {
  id                   String          @id @default(cuid())
  title                String
  slug                 String          @unique
  shortDescription     String          @db.Text
  fullDescription      String          @db.Text
  difficulty           DifficultyLevel
  estimatedCost        Decimal         @db.Decimal(10, 2)
  duration             String
  featured             Boolean         @default(false)
  status               ContentStatus   @default(DRAFT)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  // Relational fields
  authorId             String?
  author               User?           @relation(fields: [authorId], references: [id])

  categoryId           String?
  category             Category?       @relation(fields: [categoryId], references: [id])

  thumbnailImageId     String?         @unique
  thumbnailImage       Media?          @relation("ThumbnailImage", fields: [thumbnailImageId], references: [id])

  galleryImages        Media[]

  tags                 Tag[]           @relation("ProjectTags")
  technologies         Technology[]    @relation("ProjectTechnologies")

  // JSON fields for flexible, non-relational data
  hardwareComponents   Json
  softwareRequirements Json

  @@index([authorId])
  @@index([categoryId])
}

// Future Module Placeholders

model TeamMember {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  role         String
  bio          String?  @db.Text
  photoUrl     String?
  photoAlt     String?
  socialLinks  Json // SocialLink[]
  homeVisible  Boolean  @default(true)
  displayOrder Int      @default(0)
}

model Statistic {
  id    String @id @default(cuid())
  value Int
  label String
  icon  String?
  prefix String?
  suffix String?
  displayOrder Int @default(0)
}

// Generic key-value content store backing Hero, About, Why Choose,
// Innovation Journey, Final CTA — see Architecture Doc Section 10.
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "hero", "about", "benefits", "final_cta"
  data      Json
  updatedAt DateTime @updatedAt
}

model Announcement {
  id            String    @id @default(cuid())
  message       String    @db.Text
  linkText      String?
  linkHref      String?
  isActive      Boolean   @default(false)
  isDismissable Boolean   @default(true)
  startDate     DateTime?
  endDate       DateTime?
}
