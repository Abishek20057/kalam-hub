# KalamHub — Environment Variables
# Copy this file to .env.local and fill in real values.
# Module 1 does not require DATABASE_URL to be set for the app to run —
# Prisma client is configured but no queries are made until Phase 5.

# PostgreSQL connection string (required starting Phase 5)
DATABASE_URL="postgresql://user:password@localhost:5432/kalamhub?schema=public"

# Site URL (used in metadata, OG tags, canonical links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
